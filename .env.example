# Token do bot do Telegram - obrigatório
# Crie um bot conversando com o @BotFather no Telegram (/newbot) e copie o token
TELEGRAM_BOT_TOKEN=123456789:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chave de API da Groq (gratuita, sem cartão de crédito) - obrigatória
# Gere em https://console.groq.com/keys
GROQ_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo Groq a usar (Llama 3.3 70B - gratuito, sem cartão)
GROQ_MODEL=llama-3.3-70b-versatile

# IDs de usuário do Telegram autorizados a usar o bot, separados por vírgula.
# Deixe vazio para responder a qualquer pessoa que encontrar o bot.
# Dica: rode o bot com este campo vazio, mande uma mensagem para ele, e o seu
# ID aparece no log ("Mensagem de @seuuser (id 123456789)") - copie e cole aqui.
TELEGRAM_ALLOWED_IDS=

# Limite de mensagens por minuto por conversa (proteção simples contra abuso/cota)
RATE_LIMIT_PER_MINUTE=15

# Quantas trocas (pergunta+resposta) manter de histórico por conversa
HISTORY_TURNS=8
